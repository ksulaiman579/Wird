{"surah":113,"ayahs":[{"ayah":1,"arabic":"قُلۡ أَعُوذُ بِرَبِّ ٱلۡفَلَقِ","translation":"Say, \"I seek refuge in the Lord of daybreak","transliteration":"Qul aAAoothu birabbi alfalaqi","juz":30,"wordCount":4},{"ayah":2,"arabic":"مِن شَرِّ مَا خَلَقَ","translation":"From the evil of that which He created","transliteration":"Min sharri ma khalaqa","juz":30,"wordCount":4},{"ayah":3,"arabic":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ","translation":"And from the evil of darkness when it settles","transliteration":"Wamin sharri ghasiqin itha waqaba","juz":30,"wordCount":5},{"ayah":4,"arabic":"وَمِن شَرِّ ٱلنَّفَّـٰثَٰتِ فِي ٱلۡعُقَدِ","translation":"And from the evil of the blowers in knots","transliteration":"Wamin sharri alnnaffathati fee alAAuqadi","juz":30,"wordCount":5},{"ayah":5,"arabic":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ","translation":"And from the evil of an envier when he envies","transliteration":"Wamin sharri hasidin itha hasada","juz":30,"wordCount":5}]}