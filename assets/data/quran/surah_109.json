{"surah":109,"ayahs":[{"ayah":1,"arabic":"قُلۡ يَـٰٓأَيُّهَا ٱلۡكَٰفِرُونَ","translation":"Say, \"O disbelievers","transliteration":"Qul ya ayyuha alkafiroona","juz":30,"wordCount":3},{"ayah":2,"arabic":"لَآ أَعۡبُدُ مَا تَعۡبُدُونَ","translation":"I do not worship what you worship","transliteration":"La aAAbudu ma taAAbudoona","juz":30,"wordCount":4},{"ayah":3,"arabic":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","translation":"Nor are you worshippers of what I worship","transliteration":"Wala antum AAabidoona ma aAAbudu","juz":30,"wordCount":5},{"ayah":4,"arabic":"وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ","translation":"Nor will I be a worshipper of what you worship","transliteration":"Wala ana AAabidun ma AAabadtum","juz":30,"wordCount":5},{"ayah":5,"arabic":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","translation":"Nor will you be worshippers of what I worship","transliteration":"Wala antum AAabidoona ma aAAbudu","juz":30,"wordCount":5},{"ayah":6,"arabic":"لَكُمۡ دِينُكُمۡ وَلِيَ دِينِ","translation":"For you is your religion, and for me is my religion","transliteration":"Lakum deenukum waliya deeni","juz":30,"wordCount":4}]}