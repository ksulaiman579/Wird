{"surah":112,"ayahs":[{"ayah":1,"arabic":"قُلۡ هُوَ ٱللَّهُ أَحَدٌ","translation":"Say, \"He is Allah, [who is] One","transliteration":"Qul huwa Allahu ahadun","juz":30,"wordCount":4},{"ayah":2,"arabic":"ٱللَّهُ ٱلصَّمَدُ","translation":"Allah, the Eternal Refuge","transliteration":"Allahu alssamadu","juz":30,"wordCount":2},{"ayah":3,"arabic":"لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ","translation":"He neither begets nor is born","transliteration":"Lam yalid walam yooladu","juz":30,"wordCount":4},{"ayah":4,"arabic":"وَلَمۡ يَكُن لَّهُۥ كُفُوًا أَحَدُۢ","translation":"Nor is there to Him any equivalent","transliteration":"Walam yakun lahu kufuwan ahadun","juz":30,"wordCount":5}]}