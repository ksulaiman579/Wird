{"surah":94,"ayahs":[{"ayah":1,"arabic":"أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ","translation":"Did We not expand for you, [O Muhammad], your breast","transliteration":"Alam nashrah laka sadraka","juz":30,"wordCount":4},{"ayah":2,"arabic":"وَوَضَعۡنَا عَنكَ وِزۡرَكَ","translation":"And We removed from you your burden","transliteration":"WawadaAAna AAanka wizraka","juz":30,"wordCount":3},{"ayah":3,"arabic":"ٱلَّذِيٓ أَنقَضَ ظَهۡرَكَ","translation":"Which had weighed upon your back","transliteration":"Allathee anqada thahraka","juz":30,"wordCount":3},{"ayah":4,"arabic":"وَرَفَعۡنَا لَكَ ذِكۡرَكَ","translation":"And raised high for you your repute","transliteration":"WarafaAAna laka thikraka","juz":30,"wordCount":3},{"ayah":5,"arabic":"فَإِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرًا","translation":"For indeed, with hardship [will be] ease","transliteration":"Fainna maAAa alAAusri yusran","juz":30,"wordCount":4},{"ayah":6,"arabic":"إِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرٗا","translation":"Indeed, with hardship [will be] ease","transliteration":"Inna maAAa alAAusri yusran","juz":30,"wordCount":4},{"ayah":7,"arabic":"فَإِذَا فَرَغۡتَ فَٱنصَبۡ","translation":"So when you have finished [your duties], then stand up [for worship]","transliteration":"Faitha faraghta fainsab","juz":30,"wordCount":3},{"ayah":8,"arabic":"وَإِلَىٰ رَبِّكَ فَٱرۡغَب","translation":"And to your Lord direct [your] longing","transliteration":"Waila rabbika fairghab","juz":30,"wordCount":3}]}