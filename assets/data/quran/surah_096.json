{"surah":96,"ayahs":[{"ayah":1,"arabic":"ٱقۡرَأۡ بِٱسۡمِ رَبِّكَ ٱلَّذِي خَلَقَ","translation":"Recite in the name of your Lord who created","transliteration":"Iqra biismi rabbika allathee khalaqa","juz":30,"wordCount":5},{"ayah":2,"arabic":"خَلَقَ ٱلۡإِنسَٰنَ مِنۡ عَلَقٍ","translation":"Created man from a clinging substance","transliteration":"Khalaqa alinsana min AAalaqin","juz":30,"wordCount":4},{"ayah":3,"arabic":"ٱقۡرَأۡ وَرَبُّكَ ٱلۡأَكۡرَمُ","translation":"Recite, and your Lord is the most Generous","transliteration":"Iqra warabbuka alakramu","juz":30,"wordCount":3},{"ayah":4,"arabic":"ٱلَّذِي عَلَّمَ بِٱلۡقَلَمِ","translation":"Who taught by the pen","transliteration":"Allathee AAallama bialqalami","juz":30,"wordCount":3},{"ayah":5,"arabic":"عَلَّمَ ٱلۡإِنسَٰنَ مَا لَمۡ يَعۡلَمۡ","translation":"Taught man that which he knew not","transliteration":"AAallama alinsana ma lam yaAAlam","juz":30,"wordCount":5},{"ayah":6,"arabic":"كَلَّآ إِنَّ ٱلۡإِنسَٰنَ لَيَطۡغَىٰٓ","translation":"No! [But] indeed, man transgresses","transliteration":"Kalla inna alinsana layatgha","juz":30,"wordCount":4},{"ayah":7,"arabic":"أَن رَّءَاهُ ٱسۡتَغۡنَىٰٓ","translation":"Because he sees himself self-sufficient","transliteration":"An raahu istaghna","juz":30,"wordCount":3},{"ayah":8,"arabic":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجۡعَىٰٓ","translation":"Indeed, to your Lord is the return","transliteration":"Inna ila rabbika alrrujAAa","juz":30,"wordCount":4},{"ayah":9,"arabic":"أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ","translation":"Have you seen the one who forbids","transliteration":"Araayta allathee yanha","juz":30,"wordCount":3},{"ayah":10,"arabic":"عَبۡدًا إِذَا صَلَّىٰٓ","translation":"A servant when he prays","transliteration":"AAabdan itha salla","juz":30,"wordCount":3},{"ayah":11,"arabic":"أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰٓ","translation":"Have you seen if he is upon guidance","transliteration":"Araayta in kana AAala alhuda","juz":30,"wordCount":5},{"ayah":12,"arabic":"أَوۡ أَمَرَ بِٱلتَّقۡوَىٰٓ","translation":"Or enjoins righteousness","transliteration":"Aw amara bialttaqwa","juz":30,"wordCount":3},{"ayah":13,"arabic":"أَرَءَيۡتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","translation":"Have you seen if he denies and turns away","transliteration":"Araayta in kaththaba watawalla","juz":30,"wordCount":4},{"ayah":14,"arabic":"أَلَمۡ يَعۡلَم بِأَنَّ ٱللَّهَ يَرَىٰ","translation":"Does he not know that Allah sees","transliteration":"Alam yaAAlam bianna Allaha yara","juz":30,"wordCount":5},{"ayah":15,"arabic":"كَلَّا لَئِن لَّمۡ يَنتَهِ لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ","translation":"No! If he does not desist, We will surely drag him by the forelock","transliteration":"Kalla lain lam yantahi lanasfaAAan bialnnasiyati","juz":30,"wordCount":6},{"ayah":16,"arabic":"نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖ","translation":"A lying, sinning forelock","transliteration":"Nasiyatin kathibatin khatiatin","juz":30,"wordCount":3},{"ayah":17,"arabic":"فَلۡيَدۡعُ نَادِيَهُۥ","translation":"Then let him call his associates","transliteration":"FalyadAAu nadiyahu","juz":30,"wordCount":2},{"ayah":18,"arabic":"سَنَدۡعُ ٱلزَّبَانِيَةَ","translation":"We will call the angels of Hell","transliteration":"SanadAAu alzzabaniyata","juz":30,"wordCount":2},{"ayah":19,"arabic":"كَلَّا لَا تُطِعۡهُ وَٱسۡجُدۡۤ وَٱقۡتَرِب۩","translation":"No! Do not obey him. But prostrate and draw near [to Allah]","transliteration":"Kalla la tutiAAhu waosjud waiqtarib","juz":30,"wordCount":5}]}