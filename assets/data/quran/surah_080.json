{"surah":80,"ayahs":[{"ayah":1,"arabic":"عَبَسَ وَتَوَلَّىٰٓ","translation":"The Prophet frowned and turned away","transliteration":"AAabasa watawalla","juz":30,"wordCount":2},{"ayah":2,"arabic":"أَن جَآءَهُ ٱلۡأَعۡمَىٰ","translation":"Because there came to him the blind man, [interrupting]","transliteration":"An jaahu alaAAma","juz":30,"wordCount":3},{"ayah":3,"arabic":"وَمَا يُدۡرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ","translation":"But what would make you perceive, [O Muhammad], that perhaps he might be purified","transliteration":"Wama yudreeka laAAallahu yazzakka","juz":30,"wordCount":4},{"ayah":4,"arabic":"أَوۡ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكۡرَىٰٓ","translation":"Or be reminded and the remembrance would benefit him","transliteration":"Aw yaththakkaru fatanfaAAahu alththikra","juz":30,"wordCount":4},{"ayah":5,"arabic":"أَمَّا مَنِ ٱسۡتَغۡنَىٰ","translation":"As for he who thinks himself without need","transliteration":"Amma mani istaghna","juz":30,"wordCount":3},{"ayah":6,"arabic":"فَأَنتَ لَهُۥ تَصَدَّىٰ","translation":"To him you give attention","transliteration":"Faanta lahu tasadda","juz":30,"wordCount":3},{"ayah":7,"arabic":"وَمَا عَلَيۡكَ أَلَّا يَزَّكَّىٰ","translation":"And not upon you [is any blame] if he will not be purified","transliteration":"Wama AAalayka alla yazzakka","juz":30,"wordCount":4},{"ayah":8,"arabic":"وَأَمَّا مَن جَآءَكَ يَسۡعَىٰ","translation":"But as for he who came to you striving [for knowledge]","transliteration":"Waamma man jaaka yasAAa","juz":30,"wordCount":4},{"ayah":9,"arabic":"وَهُوَ يَخۡشَىٰ","translation":"While he fears [Allah]","transliteration":"Wahuwa yakhsha","juz":30,"wordCount":2},{"ayah":10,"arabic":"فَأَنتَ عَنۡهُ تَلَهَّىٰ","translation":"From him you are distracted","transliteration":"Faanta AAanhu talahha","juz":30,"wordCount":3},{"ayah":11,"arabic":"كَلَّآ إِنَّهَا تَذۡكِرَةٞ","translation":"No! Indeed, these verses are a reminder","transliteration":"Kalla innaha tathkiratun","juz":30,"wordCount":3},{"ayah":12,"arabic":"فَمَن شَآءَ ذَكَرَهُۥ","translation":"So whoever wills may remember it","transliteration":"Faman shaa thakarahu","juz":30,"wordCount":3},{"ayah":13,"arabic":"فِي صُحُفٖ مُّكَرَّمَةٖ","translation":"[It is recorded] in honored sheets","transliteration":"Fee suhufin mukarramatin","juz":30,"wordCount":3},{"ayah":14,"arabic":"مَّرۡفُوعَةٖ مُّطَهَّرَةِۭ","translation":"Exalted and purified","transliteration":"MarfooAAatin mutahharatin","juz":30,"wordCount":2},{"ayah":15,"arabic":"بِأَيۡدِي سَفَرَةٖ","translation":"[Carried] by the hands of messenger-angels","transliteration":"Biaydee safaratin","juz":30,"wordCount":2},{"ayah":16,"arabic":"كِرَامِۭ بَرَرَةٖ","translation":"Noble and dutiful","transliteration":"Kiramin bararatin","juz":30,"wordCount":2},{"ayah":17,"arabic":"قُتِلَ ٱلۡإِنسَٰنُ مَآ أَكۡفَرَهُۥ","translation":"Cursed is man; how disbelieving is he","transliteration":"Qutila alinsanu ma akfarahu","juz":30,"wordCount":4},{"ayah":18,"arabic":"مِنۡ أَيِّ شَيۡءٍ خَلَقَهُۥ","translation":"From what substance did He create him","transliteration":"Min ayyi shayin khalaqahu","juz":30,"wordCount":4},{"ayah":19,"arabic":"مِن نُّطۡفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ","translation":"From a sperm-drop He created him and destined for him","transliteration":"Min nutfatin khalaqahu faqaddarahu","juz":30,"wordCount":4},{"ayah":20,"arabic":"ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ","translation":"Then He eased the way for him","transliteration":"Thumma alssabeela yassarahu","juz":30,"wordCount":3},{"ayah":21,"arabic":"ثُمَّ أَمَاتَهُۥ فَأَقۡبَرَهُۥ","translation":"Then He causes his death and provides a grave for him","transliteration":"Thumma amatahu faaqbarahu","juz":30,"wordCount":3},{"ayah":22,"arabic":"ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ","translation":"Then when He wills, He will resurrect him","transliteration":"Thumma itha shaa ansharahu","juz":30,"wordCount":4},{"ayah":23,"arabic":"كَلَّا لَمَّا يَقۡضِ مَآ أَمَرَهُۥ","translation":"No! Man has not yet accomplished what He commanded him","transliteration":"Kalla lamma yaqdi ma amarahu","juz":30,"wordCount":5},{"ayah":24,"arabic":"فَلۡيَنظُرِ ٱلۡإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ","translation":"Then let mankind look at his food","transliteration":"Falyanthuri alinsanu ila taAAamihi","juz":30,"wordCount":4},{"ayah":25,"arabic":"أَنَّا صَبَبۡنَا ٱلۡمَآءَ صَبّٗا","translation":"How We poured down water in torrents","transliteration":"Anna sababna almaa sabban","juz":30,"wordCount":4},{"ayah":26,"arabic":"ثُمَّ شَقَقۡنَا ٱلۡأَرۡضَ شَقّٗا","translation":"Then We broke open the earth, splitting [it with sprouts]","transliteration":"Thumma shaqaqna alarda shaqqan","juz":30,"wordCount":4},{"ayah":27,"arabic":"فَأَنۢبَتۡنَا فِيهَا حَبّٗا","translation":"And caused to grow within it grain","transliteration":"Faanbatna feeha habban","juz":30,"wordCount":3},{"ayah":28,"arabic":"وَعِنَبٗا وَقَضۡبٗا","translation":"And grapes and herbage","transliteration":"WaAAinaban waqadban","juz":30,"wordCount":2},{"ayah":29,"arabic":"وَزَيۡتُونٗا وَنَخۡلٗا","translation":"And olive and palm trees","transliteration":"Wazaytoonan wanakhlan","juz":30,"wordCount":2},{"ayah":30,"arabic":"وَحَدَآئِقَ غُلۡبٗا","translation":"And gardens of dense shrubbery","transliteration":"Wahadaiqa ghulban","juz":30,"wordCount":2},{"ayah":31,"arabic":"وَفَٰكِهَةٗ وَأَبّٗا","translation":"And fruit and grass","transliteration":"Wafakihatan waabban","juz":30,"wordCount":2},{"ayah":32,"arabic":"مَّتَٰعٗا لَّكُمۡ وَلِأَنۡعَٰمِكُمۡ","translation":"[As] enjoyment for you and your grazing livestock","transliteration":"MataAAan lakum walianAAamikum","juz":30,"wordCount":3},{"ayah":33,"arabic":"فَإِذَا جَآءَتِ ٱلصَّآخَّةُ","translation":"But when there comes the Deafening Blast","transliteration":"Faitha jaati alssakhkhatu","juz":30,"wordCount":3},{"ayah":34,"arabic":"يَوۡمَ يَفِرُّ ٱلۡمَرۡءُ مِنۡ أَخِيهِ","translation":"On the Day a man will flee from his brother","transliteration":"Yawma yafirru almaro min akheehi","juz":30,"wordCount":5},{"ayah":35,"arabic":"وَأُمِّهِۦ وَأَبِيهِ","translation":"And his mother and his father","transliteration":"Waommihi waabeehi","juz":30,"wordCount":2},{"ayah":36,"arabic":"وَصَٰحِبَتِهِۦ وَبَنِيهِ","translation":"And his wife and his children","transliteration":"Wasahibatihi wabaneehi","juz":30,"wordCount":2},{"ayah":37,"arabic":"لِكُلِّ ٱمۡرِيٕٖ مِّنۡهُمۡ يَوۡمَئِذٖ شَأۡنٞ يُغۡنِيهِ","translation":"For every man, that Day, will be a matter adequate for him","transliteration":"Likulli imriin minhum yawmaithin shanun yughneehi","juz":30,"wordCount":6},{"ayah":38,"arabic":"وُجُوهٞ يَوۡمَئِذٖ مُّسۡفِرَةٞ","translation":"[Some] faces, that Day, will be bright","transliteration":"Wujoohun yawmaithin musfiratun","juz":30,"wordCount":3},{"ayah":39,"arabic":"ضَاحِكَةٞ مُّسۡتَبۡشِرَةٞ","translation":"Laughing, rejoicing at good news","transliteration":"Dahikatun mustabshiratun","juz":30,"wordCount":2},{"ayah":40,"arabic":"وَوُجُوهٞ يَوۡمَئِذٍ عَلَيۡهَا غَبَرَةٞ","translation":"And [other] faces, that Day, will have upon them dust","transliteration":"Wawujoohun yawmaithin AAalayha ghabaratun","juz":30,"wordCount":4},{"ayah":41,"arabic":"تَرۡهَقُهَا قَتَرَةٌ","translation":"Blackness will cover them","transliteration":"Tarhaquha qataratun","juz":30,"wordCount":2},{"ayah":42,"arabic":"أُوْلَـٰٓئِكَ هُمُ ٱلۡكَفَرَةُ ٱلۡفَجَرَةُ","translation":"Those are the disbelievers, the wicked ones","transliteration":"Olaika humu alkafaratu alfajaratu","juz":30,"wordCount":4}]}