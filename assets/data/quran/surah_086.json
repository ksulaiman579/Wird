{"surah":86,"ayahs":[{"ayah":1,"arabic":"وَٱلسَّمَآءِ وَٱلطَّارِقِ","translation":"By the sky and the night comer","transliteration":"Waalssamai waalttariqi","juz":30,"wordCount":2},{"ayah":2,"arabic":"وَمَآ أَدۡرَىٰكَ مَا ٱلطَّارِقُ","translation":"And what can make you know what is the night comer","transliteration":"Wama adraka ma alttariqu","juz":30,"wordCount":4},{"ayah":3,"arabic":"ٱلنَّجۡمُ ٱلثَّاقِبُ","translation":"It is the piercing star","transliteration":"Alnnajmu alththaqibu","juz":30,"wordCount":2},{"ayah":4,"arabic":"إِن كُلُّ نَفۡسٖ لَّمَّا عَلَيۡهَا حَافِظٞ","translation":"There is no soul but that it has over it a protector","transliteration":"In kullu nafsin lamma AAalayha hafithun","juz":30,"wordCount":6},{"ayah":5,"arabic":"فَلۡيَنظُرِ ٱلۡإِنسَٰنُ مِمَّ خُلِقَ","translation":"So let man observe from what he was created","transliteration":"Falyanthuri alinsanu mimma khuliqa","juz":30,"wordCount":4},{"ayah":6,"arabic":"خُلِقَ مِن مَّآءٖ دَافِقٖ","translation":"He was created from a fluid, ejected","transliteration":"Khuliqa min main dafiqin","juz":30,"wordCount":4},{"ayah":7,"arabic":"يَخۡرُجُ مِنۢ بَيۡنِ ٱلصُّلۡبِ وَٱلتَّرَآئِبِ","translation":"Emerging from between the backbone and the ribs","transliteration":"Yakhruju min bayni alssulbi waalttaraibi","juz":30,"wordCount":5},{"ayah":8,"arabic":"إِنَّهُۥ عَلَىٰ رَجۡعِهِۦ لَقَادِرٞ","translation":"Indeed, Allah, to return him [to life], is Able","transliteration":"Innahu AAala rajAAihi laqadirun","juz":30,"wordCount":4},{"ayah":9,"arabic":"يَوۡمَ تُبۡلَى ٱلسَّرَآئِرُ","translation":"The Day when secrets will be put on trial","transliteration":"Yawma tubla alssarairu","juz":30,"wordCount":3},{"ayah":10,"arabic":"فَمَا لَهُۥ مِن قُوَّةٖ وَلَا نَاصِرٖ","translation":"Then man will have no power or any helper","transliteration":"Fama lahu min quwwatin wala nasirin","juz":30,"wordCount":6},{"ayah":11,"arabic":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجۡعِ","translation":"By the sky which returns [rain]","transliteration":"Waalssamai thati alrrajAAi","juz":30,"wordCount":3},{"ayah":12,"arabic":"وَٱلۡأَرۡضِ ذَاتِ ٱلصَّدۡعِ","translation":"And [by] the earth which cracks open","transliteration":"Waalardi thati alssadAAi","juz":30,"wordCount":3},{"ayah":13,"arabic":"إِنَّهُۥ لَقَوۡلٞ فَصۡلٞ","translation":"Indeed, the Qur'an is a decisive statement","transliteration":"Innahu laqawlun faslun","juz":30,"wordCount":3},{"ayah":14,"arabic":"وَمَا هُوَ بِٱلۡهَزۡلِ","translation":"And it is not amusement","transliteration":"Wama huwa bialhazli","juz":30,"wordCount":3},{"ayah":15,"arabic":"إِنَّهُمۡ يَكِيدُونَ كَيۡدٗا","translation":"Indeed, they are planning a plan","transliteration":"Innahum yakeedoona kaydan","juz":30,"wordCount":3},{"ayah":16,"arabic":"وَأَكِيدُ كَيۡدٗا","translation":"But I am planning a plan","transliteration":"Waakeedu kaydan","juz":30,"wordCount":2},{"ayah":17,"arabic":"فَمَهِّلِ ٱلۡكَٰفِرِينَ أَمۡهِلۡهُمۡ رُوَيۡدَۢا","translation":"So allow time for the disbelievers. Leave them awhile","transliteration":"Famahhili alkafireena amhilhum ruwaydan","juz":30,"wordCount":4}]}