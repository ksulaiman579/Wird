{"surah":93,"ayahs":[{"ayah":1,"arabic":"وَٱلضُّحَىٰ","translation":"By the morning brightness","transliteration":"Waaldduha","juz":30,"wordCount":1},{"ayah":2,"arabic":"وَٱلَّيۡلِ إِذَا سَجَىٰ","translation":"And [by] the night when it covers with darkness","transliteration":"Waallayli itha saja","juz":30,"wordCount":3},{"ayah":3,"arabic":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","translation":"Your Lord has not taken leave of you, [O Muhammad], nor has He detested [you]","transliteration":"Ma waddaAAaka rabbuka wama qala","juz":30,"wordCount":5},{"ayah":4,"arabic":"وَلَلۡأٓخِرَةُ خَيۡرٞ لَّكَ مِنَ ٱلۡأُولَىٰ","translation":"And the Hereafter is better for you than the first [life]","transliteration":"Walalakhiratu khayrun laka mina aloola","juz":30,"wordCount":5},{"ayah":5,"arabic":"وَلَسَوۡفَ يُعۡطِيكَ رَبُّكَ فَتَرۡضَىٰٓ","translation":"And your Lord is going to give you, and you will be satisfied","transliteration":"Walasawfa yuAAteeka rabbuka fatarda","juz":30,"wordCount":4},{"ayah":6,"arabic":"أَلَمۡ يَجِدۡكَ يَتِيمٗا فَـَٔاوَىٰ","translation":"Did He not find you an orphan and give [you] refuge","transliteration":"Alam yajidka yateeman faawa","juz":30,"wordCount":4},{"ayah":7,"arabic":"وَوَجَدَكَ ضَآلّٗا فَهَدَىٰ","translation":"And He found you lost and guided [you]","transliteration":"Wawajadaka dallan fahada","juz":30,"wordCount":3},{"ayah":8,"arabic":"وَوَجَدَكَ عَآئِلٗا فَأَغۡنَىٰ","translation":"And He found you poor and made [you] self-sufficient","transliteration":"Wawajadaka AAailan faaghna","juz":30,"wordCount":3},{"ayah":9,"arabic":"فَأَمَّا ٱلۡيَتِيمَ فَلَا تَقۡهَرۡ","translation":"So as for the orphan, do not oppress [him]","transliteration":"Faamma alyateema fala taqhar","juz":30,"wordCount":4},{"ayah":10,"arabic":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنۡهَرۡ","translation":"And as for the petitioner, do not repel [him]","transliteration":"Waamma alssaila fala tanhar","juz":30,"wordCount":4},{"ayah":11,"arabic":"وَأَمَّا بِنِعۡمَةِ رَبِّكَ فَحَدِّثۡ","translation":"But as for the favor of your Lord, report [it]","transliteration":"Waamma biniAAmati rabbika fahaddith","juz":30,"wordCount":4}]}