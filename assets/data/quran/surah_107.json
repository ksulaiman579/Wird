{"surah":107,"ayahs":[{"ayah":1,"arabic":"أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ","translation":"Have you seen the one who denies the Recompense","transliteration":"Araayta allathee yukaththibu bialddeeni","juz":30,"wordCount":4},{"ayah":2,"arabic":"فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ","translation":"For that is the one who drives away the orphan","transliteration":"Fathalika allathee yaduAAAAu alyateema","juz":30,"wordCount":4},{"ayah":3,"arabic":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ","translation":"And does not encourage the feeding of the poor","transliteration":"Wala yahuddu AAala taAAami almiskeeni","juz":30,"wordCount":5},{"ayah":4,"arabic":"فَوَيۡلٞ لِّلۡمُصَلِّينَ","translation":"So woe to those who pray","transliteration":"Fawaylun lilmusalleena","juz":30,"wordCount":2},{"ayah":5,"arabic":"ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ","translation":"[But] who are heedless of their prayer","transliteration":"Allatheena hum AAan salatihim sahoona","juz":30,"wordCount":5},{"ayah":6,"arabic":"ٱلَّذِينَ هُمۡ يُرَآءُونَ","translation":"Those who make show [of their deeds]","transliteration":"Allatheena hum yuraoona","juz":30,"wordCount":3},{"ayah":7,"arabic":"وَيَمۡنَعُونَ ٱلۡمَاعُونَ","translation":"And withhold [simple] assistance","transliteration":"WayamnaAAoona almaAAoona","juz":30,"wordCount":2}]}