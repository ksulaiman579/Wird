{"surah":104,"ayahs":[{"ayah":1,"arabic":"وَيۡلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ","translation":"Woe to every scorner and mocker","transliteration":"Waylun likulli humazatin lumazatin","juz":30,"wordCount":4},{"ayah":2,"arabic":"ٱلَّذِي جَمَعَ مَالٗا وَعَدَّدَهُۥ","translation":"Who collects wealth and [continuously] counts it","transliteration":"Allathee jamaAAa malan waAAaddadahu","juz":30,"wordCount":4},{"ayah":3,"arabic":"يَحۡسَبُ أَنَّ مَالَهُۥٓ أَخۡلَدَهُۥ","translation":"He thinks that his wealth will make him immortal","transliteration":"Yahsabu anna malahu akhladahu","juz":30,"wordCount":4},{"ayah":4,"arabic":"كَلَّاۖ لَيُنۢبَذَنَّ فِي ٱلۡحُطَمَةِ","translation":"No! He will surely be thrown into the Crusher","transliteration":"Kalla layunbathanna fee alhutamati","juz":30,"wordCount":4},{"ayah":5,"arabic":"وَمَآ أَدۡرَىٰكَ مَا ٱلۡحُطَمَةُ","translation":"And what can make you know what is the Crusher","transliteration":"Wama adraka ma alhutamatu","juz":30,"wordCount":4},{"ayah":6,"arabic":"نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ","translation":"It is the fire of Allah, [eternally] fueled","transliteration":"Naru Allahi almooqadatu","juz":30,"wordCount":3},{"ayah":7,"arabic":"ٱلَّتِي تَطَّلِعُ عَلَى ٱلۡأَفۡـِٔدَةِ","translation":"Which mounts directed at the hearts","transliteration":"Allatee tattaliAAu AAala alafidati","juz":30,"wordCount":4},{"ayah":8,"arabic":"إِنَّهَا عَلَيۡهِم مُّؤۡصَدَةٞ","translation":"Indeed, Hellfire will be closed down upon them","transliteration":"lnnaha AAalayhim musadatun","juz":30,"wordCount":3},{"ayah":9,"arabic":"فِي عَمَدٖ مُّمَدَّدَةِۭ","translation":"In extended columns","transliteration":"Fee AAamadin mumaddadatin","juz":30,"wordCount":3}]}